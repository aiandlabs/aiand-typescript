{
  "name": "@aiand/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the ai& API, generated from the public OpenAPI spec.",
  "license": "Apache-2.0",
  "author": "ai&",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiandlabs/aiand-typescript.git"
  },
  "homepage": "https://docs.aiand.com",
  "bugs": {
    "url": "https://github.com/aiandlabs/aiand-typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "aiand",
    "ai&",
    "openai-compatible",
    "openapi",
    "sdk",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "update-sdk": "./scripts/update-sdk",
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:vcr": "vitest run tests/openai-api-vcr.test.ts",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@pollyjs/adapter-fetch": "^6.0.7",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "@types/node": "^20.19.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8"
  }
}
