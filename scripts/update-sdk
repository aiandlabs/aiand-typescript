#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RAW_SPEC="$(mktemp)"
OPENAPI_GENERATOR_CLI="@openapitools/openapi-generator-cli@2.34.0"

trap 'rm -f "$RAW_SPEC"' EXIT

curl -fsSL "https://api.aiand.com/openapi.json" -o "$RAW_SPEC"
python3 -m json.tool --indent 2 "$RAW_SPEC" "$ROOT_DIR/openapi/openapi.json"

cd "$ROOT_DIR"

npx --yes "$OPENAPI_GENERATOR_CLI" generate \
  -i "$ROOT_DIR/openapi/openapi.json" \
  -g typescript-fetch \
  -o "$ROOT_DIR" \
  -c "$ROOT_DIR/openapi-generator-config.yaml" \
  --global-property apiTests=false,modelTests=false

node "$ROOT_DIR/scripts/patch-generated-client.mjs" "$ROOT_DIR"
